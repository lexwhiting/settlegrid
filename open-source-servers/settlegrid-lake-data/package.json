    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "settlegrid",
    "mcp",
    "ai",
    "lake",
    "reservoir",
    "water-level",
    "hydrology",
    "usgs"
  ],
