{
  "name": "settlegrid-bioarxiv",
  "version": "1.0.0",
  "description": "MCP server for bioRxiv Biology Preprints with SettleGrid billing. Access biology preprints from bioRxiv including recent papers, search, and paper details. No API key needed.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@settlegrid/mcp": "^0.1.1"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "settlegrid",
    "mcp",
    "ai",
    "biorxiv",
    "preprints",
    "biology",
    "life-sciences",
    "research"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/settlegrid/settlegrid-bioarxiv"
  }
}
