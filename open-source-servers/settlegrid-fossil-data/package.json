{
  "name": "settlegrid-fossil-data",
  "version": "1.0.0",
  "description": "MCP server for Fossil Record Data with SettleGrid billing. Access fossil record data via the Paleobiology Database (PBDB). Search fossils, get occurrences, and look up taxa.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@settlegrid/mcp": "^0.1.1"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "settlegrid",
    "mcp",
    "ai",
    "fossil",
    "paleontology",
    "paleobiology",
    "pbdb",
    "taxonomy",
    "evolution"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/settlegrid/settlegrid-fossil-data"
  }
}
