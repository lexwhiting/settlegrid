  },
  "keywords": [
    "settlegrid",
    "mcp",
    "ai",
    "etymology",
    "dictionary",
    "definition",
    "language",
    "words",
    "phonetics"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/settlegrid/settlegrid-etymology"
  }
