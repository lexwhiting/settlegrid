{
  "name": "settlegrid-ham-radio",
  "version": "1.0.0",
  "description": "MCP server for Ham Radio Callsign Lookup with SettleGrid billing. Look up amateur radio callsigns, licensee data, and DXCC entities via Callook. No API key needed.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@settlegrid/mcp": "^0.1.1"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "settlegrid",
    "mcp",
    "ai",
    "ham-radio",
    "amateur-radio",
    "callsign",
    "fcc",
    "dxcc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/settlegrid/settlegrid-ham-radio"
  }
}
