{
  "name": "settlegrid-plant-data",
  "version": "1.0.0",
  "description": "MCP server for Plant Biology Data with SettleGrid billing. Access plant species data via GBIF (Global Biodiversity Information Facility). Search plants, get species details, and list families.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@settlegrid/mcp": "^0.1.1"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "settlegrid",
    "mcp",
    "ai",
    "plants",
    "botany",
    "biodiversity",
    "species",
    "gbif",
    "ecology"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/settlegrid/settlegrid-plant-data"
  }
}
