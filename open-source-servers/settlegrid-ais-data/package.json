{
  "name": "settlegrid-ais-data",
  "version": "1.0.0",
  "description": "MCP server for Ship AIS Data with SettleGrid billing. Access ship AIS tracking data from the Finnish Digitraffic marine API. Free and open, no API key needed.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@settlegrid/mcp": "^0.1.1"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "settlegrid",
    "mcp",
    "ai",
    "ais",
    "ships",
    "marine",
    "vessel-tracking",
    "maritime"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/settlegrid/settlegrid-ais-data"
  }
}
