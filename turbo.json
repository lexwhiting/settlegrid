{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "DATABASE_URL",
        "REDIS_URL",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "SUPABASE_SERVICE_ROLE_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_CONNECT_CLIENT_ID",
        "STRIPE_WEBHOOK_SECRET",
        "RESEND_API_KEY",
        "GATE_PASSWORD",
        "GATE_SECRET",
        "CRON_SECRET",
        "JWT_SECRET",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "SETTLEGRID_GAS_WALLET_KEY",
        "AP2_SIGNING_SECRET",
        "OPEN_EXCHANGE_RATES_API_KEY",
        "ANTHROPIC_API_KEY",
        "STRIPE_PRICE_STARTER",
        "STRIPE_PRICE_GROWTH",
        "STRIPE_PRICE_SCALE"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": false
    },
    "lint": {},
    "//#build:registry": {
      "cache": false,
      "dependsOn": []
    }
  }
}
