{
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "cd ../.. && npx turbo build --filter=@settlegrid/web",
  "crons": [
    {
      "path": "/api/cron/health-checks",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/webhook-retry",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/alert-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/abandoned-checkout",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/expire-sessions",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/aggregate-usage",
      "schedule": "0 0 * * *"
    }
  ]
}
