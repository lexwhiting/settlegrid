# SettleGrid Web — Required Environment Variables
# Copy to .env.local and fill in values

# PostgreSQL database connection
DATABASE_URL=postgres://user:password@localhost:5433/settlegrid

# Upstash Redis for rate limiting and caching
REDIS_URL=redis://localhost:6380
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Stripe billing and payouts
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CONNECT_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend email delivery
RESEND_API_KEY=re_...

# JWT signing secret (min 32 chars)
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# Application URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3005

# Optional: Password gate for private beta
# GATE_PASSWORD=your_gate_password
# GATE_SECRET=your_gate_signing_secret
# GATE_AUTH_TIMEOUT_HOURS=24

# Optional: Cron endpoint authentication
# CRON_SECRET=your_cron_secret

# Optional: Redis health check token
# REDIS_TOKEN=your_redis_token
