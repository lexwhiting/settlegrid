{
  "name": "@settlegrid/cli",
  "version": "0.1.0",
  "description": "SettleGrid CLI — monetize any MCP server, REST API, or AI agent with one command.",
  "keywords": [
    "settlegrid",
    "cli",
    "mcp",
    "monetization",
    "ai-economy",
    "codemod",
    "scaffold"
  ],
  "homepage": "https://settlegrid.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/lexwhiting/settlegrid.git",
    "directory": "packages/settlegrid-cli"
  },
  "bugs": {
    "url": "https://github.com/lexwhiting/settlegrid/issues",
    "email": "support@settlegrid.ai"
  },
  "author": {
    "name": "Alerterra, LLC",
    "email": "support@settlegrid.ai",
    "url": "https://settlegrid.ai"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "settlegrid": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@octokit/rest": "^21.0.2",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "giget": "^1.2.3",
    "jscodeshift": "^17.3.0",
    "kleur": "^4.1.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
