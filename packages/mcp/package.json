{
  "name": "@settlegrid/mcp",
  "version": "0.2.0",
  "description": "The Settlement Layer for the AI Economy — monetize any MCP tool, REST API, or AI agent with per-call billing, real-time metering, and automated Stripe payouts.",
  "keywords": [
    "settlegrid",
    "mcp",
    "model-context-protocol",
    "ai-agent-payments",
    "settlement-layer",
    "monetization",
    "metering",
    "billing",
    "per-call-pricing",
    "budget-enforcement",
    "stripe",
    "ai-commerce",
    "ai",
    "payments",
    "sdk",
    "api-billing",
    "usage-based-billing",
    "x402",
    "agent-payments",
    "stripe-connect",
    "ai-agents",
    "llm",
    "ai-tools",
    "micropayments",
    "revenue-sharing",
    "ai-monetization",
    "mcp-server",
    "mcp-billing",
    "ai-economy",
    "agent-commerce"
  ],
  "homepage": "https://settlegrid.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/lexwhiting/settlegrid.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/lexwhiting/settlegrid/issues",
    "email": "support@settlegrid.ai"
  },
  "author": {
    "name": "Alerterra, LLC",
    "email": "support@settlegrid.ai",
    "url": "https://settlegrid.ai"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./kernel": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node scripts/generate-template-schema.cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod-to-json-schema": "^3.23.0",
    "@types/node": "^22.0.0"
  }
}
